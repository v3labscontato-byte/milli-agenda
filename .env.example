# Database
DATABASE_URL="postgresql://user:password@localhost:5432/milli_agenda?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# API
API_PORT=3001
API_HOST="0.0.0.0"

# Web (Next.js public vars)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Storage (S3-compatible)
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="milli-agenda"
STORAGE_REGION="us-east-1"

# Email
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@milliagenda.com"

# Webhooks
WEBHOOK_SECRET=""

# Environment
NODE_ENV="development"
