# Database
DATABASE_URL="postgresql://user:pass@host:5432/milli_agenda"
DIRECT_URL="postgresql://user:pass@host:5432/milli_agenda"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="generate-with-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="generate-with-openssl-rand-base64-32"
JWT_REFRESH_EXPIRES_IN="30d"

# App
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV=production
CORS_ORIGIN="https://milli-agenda.vercel.app"
