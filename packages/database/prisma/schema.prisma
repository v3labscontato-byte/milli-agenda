generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PlanSlug {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  MANAGER
  PROFESSIONAL
  RECEPTIONIST
  CLIENT
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_SERVICE
  AWAITING_PAYMENT
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum CommandStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  REFUNDED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BANK_TRANSFER
  VOUCHER
}

enum ProductUnit {
  UNIT
  ML
  G
  KG
  LITER
}

enum ProductClassification {
  RESALE
  INTERNAL_USE
  PROCEDURE
  CONSUMABLE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  plan        PlanSlug  @default(FREE)
  document    String?
  phone       String?
  email       String?
  logoUrl       String?
  coverImageUrl String?
  primaryColor  String?  @default("#3D2B1F")
  active               Boolean   @default(true)
  trialEndsAt          DateTime?
  onboardingCompleted  Boolean   @default(false)
  nichoSlug            String?
  // Horários de funcionamento
  businessHours        Json?
  slotGapMinutes       Int       @default(30)
  minAdvanceHours      Int       @default(0)
  maxAdvanceDays       Int       @default(60)
  // Formas de pagamento aceitas
  acceptedPaymentMethods Json    @default("[\"PIX\",\"CASH\",\"CREDIT_CARD\",\"DEBIT_CARD\",\"VOUCHER\",\"BANK_TRANSFER\"]")
  // Dados do salão
  slogan               String?
  address              String?
  neighborhood         String?
  cep                  String?
  city                 String?
  state                String?
  // Política de Sinal
  depositRequired      Boolean   @default(false)
  depositType          String    @default("none")
  depositValue         Decimal?  @db.Decimal(10, 2)
  // Política de Cancelamento
  cancellationMinHours    Int     @default(24)
  cancellationFeePercent  Int     @default(0)
  cancellationRefundSignal Boolean @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users               User[]
  roles               Role[]
  professionals       Professional[]
  services            Service[]
  products            Product[]
  clients             Client[]
  professionalRoles   ProfessionalRole[]
  serviceCategories   ServiceCategory[]
  appointments        Appointment[]
  commands            Command[]
  payments            Payment[]
  schedules           Schedule[]
  notifications       Notification[]
  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  goals               Goal[]
  specialties         Specialty[]
  commissionPayments  CommissionPayment[]
  chartOfAccounts     ChartOfAccount[]
  chartOfAccountEntries ChartOfAccountEntry[]
  expenses            Expense[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String
  role         UserRole @default(RECEPTIONIST)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional         Professional?
  roleAssignments      UserRoleAssignment[]
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions     RolePermission[]
  userAssignments UserRoleAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String @id @default(cuid())
  resource    String
  action      String
  description String?

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role_assignments")
}

model Professional {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?  @unique
  name          String
  email         String?
  phone         String?
  specialty     String?
  avatarUrl     String?
  commissionPct Decimal? @db.Decimal(5, 2)
  active        Boolean  @default(true)
  workDays      Int[]    @default([])
  workStart     String?  @default("08:00")
  workEnd       String?  @default("18:00")
  cpf           String?
  birthDate     String?
  vinculo         String?
  enabledServices    String[]  @default([])
  allowSimultaneous  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User?                 @relation(fields: [userId], references: [id])
  appointments        Appointment[]
  schedules           Schedule[]
  specialties         ProfessionalSpecialty[]
  commissionPayments  CommissionPayment[]

  @@index([tenantId])
  @@map("professionals")
}

model Service {
  id          String   @id @default(cuid())
  tenantId    String
  categoryId  String?
  name        String
  description String?
  durationMin Int
  price       Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
  appointments Appointment[]
  commandItems CommandItem[]

  @@index([tenantId])
  @@map("services")
}

model Client {
  id           String    @id @default(cuid())
  clientNumber Int?
  tenantId     String
  name         String
  email                  String?
  phone                  String?
  birthDate              DateTime?
  notes                  String?
  cpf                    String?
  favoriteProfessionalId String?
  createdAt              DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  commands     Command[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("clients")
}

model Appointment {
  id             String            @id @default(cuid())
  tenantId       String
  clientId       String
  professionalId String
  serviceId      String
  commandId      String?
  status         AppointmentStatus @default(SCHEDULED)
  startAt        DateTime
  endAt          DateTime
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])
  command      Command?     @relation(fields: [commandId], references: [id])

  @@index([tenantId, startAt])
  @@index([professionalId, startAt])
  @@map("appointments")
}

model Command {
  id             String        @id @default(cuid())
  tenantId       String
  clientId       String
  status         CommandStatus @default(OPEN)
  totalAmount    Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  finalAmount    Decimal       @default(0) @db.Decimal(10, 2)
  notes          String?
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id])
  items        CommandItem[]
  payments     Payment[]
  appointments Appointment[]

  @@index([tenantId, status])
  @@index([clientId])
  @@map("commands")
}

model CommandItem {
  id        String   @id @default(cuid())
  commandId String
  serviceId String?
  productId String?
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  discount  Decimal  @default(0) @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  command Command  @relation(fields: [commandId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([commandId])
  @@map("command_items")
}

model Payment {
  id           String        @id @default(cuid())
  tenantId     String
  commandId    String
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  amount       Decimal       @db.Decimal(10, 2)
  externalId   String?
  gatewayData  Json?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  command Command @relation(fields: [commandId], references: [id])

  @@index([tenantId, status])
  @@index([commandId])
  @@map("payments")
}

model Schedule {
  id             String   @id @default(cuid())
  tenantId       String
  professionalId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  active         Boolean  @default(true)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek, startTime])
  @@index([tenantId, professionalId])
  @@map("schedules")
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String?
  type      String
  channel   String
  recipient String
  subject   String?
  body      String
  metadata  Json?
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type])
  @@map("notifications")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  keyHash    String    @unique
  prefix     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Onboarding / Template Engine ────────────────────────────────────────────

model NichoTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  icon        String
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  roles      NichoTemplateRole[]
  categories NichoTemplateCategory[]
  services   NichoTemplateService[]

  @@map("nicho_templates")
}

model NichoTemplateRole {
  id      String        @id @default(cuid())
  nichoId String
  name    String
  order   Int           @default(0)
  nicho   NichoTemplate @relation(fields: [nichoId], references: [id], onDelete: Cascade)

  @@map("nicho_template_roles")
}

model NichoTemplateCategory {
  id      String        @id @default(cuid())
  nichoId String
  name    String
  color   String        @default("#2563EB")
  order   Int           @default(0)
  nicho   NichoTemplate @relation(fields: [nichoId], references: [id], onDelete: Cascade)
  services NichoTemplateService[]

  @@map("nicho_template_categories")
}

model NichoTemplateService {
  id         String                 @id @default(cuid())
  nichoId    String
  categoryId String?
  name       String
  duration   Int                    @default(60)
  price      Decimal                @default(0) @db.Decimal(10, 2)
  order      Int                    @default(0)
  nicho      NichoTemplate          @relation(fields: [nichoId], references: [id], onDelete: Cascade)
  category   NichoTemplateCategory? @relation(fields: [categoryId], references: [id])

  @@map("nicho_template_services")
}

// ─── Tenant-level configurable types ─────────────────────────────────────────

model ProfessionalRole {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  status      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("professional_roles")
}

model ServiceCategory {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  color     String    @default("#2563EB")
  order     Int       @default(0)
  status    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]
  products Product[]

  @@index([tenantId])
  @@map("service_categories")
}

model Product {
  id              String                  @id @default(cuid())
  tenantId        String
  categoryId      String?
  name            String
  description     String?
  notes           String?
  price           Decimal                 @db.Decimal(10, 2)
  stockQuantity   Int                     @default(0)
  minStockAlert   Int                     @default(0)
  maxStock        Int?
  active          Boolean                 @default(true)
  sku             String?
  brand           String?
  supplierName    String?
  unit            ProductUnit             @default(UNIT)
  imageUrl        String?
  classifications ProductClassification[]
  location        String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
  commandItems CommandItem[]

  @@index([tenantId, active])
  @@map("products")
}

model Goal {
  id         String   @id @default(cuid())
  tenantId   String
  tipo       String
  periodo    String
  valor      Decimal  @db.Decimal(12, 2)
  dataInicio DateTime
  dataFim    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("goals")
}

model Specialty {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionals ProfessionalSpecialty[]

  @@index([tenantId])
  @@map("specialties")
}

model ProfessionalSpecialty {
  professionalId String
  specialtyId    String

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  specialty    Specialty    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([professionalId, specialtyId])
  @@map("professional_specialties")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

model CommissionPayment {
  id             String   @id @default(cuid())
  tenantId       String
  professionalId String
  period         String
  amount         Decimal  @db.Decimal(10, 2)
  paidAt         DateTime @default(now())
  comprovanteUrl String?
  createdAt      DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([tenantId, professionalId])
  @@map("commission_payments")
}

model ChartOfAccount {
  id           String   @id @default(cuid())
  tenantId     String
  nome         String
  tipo         String
  categoria    String
  valorPadrao  Decimal? @db.Decimal(10, 2)
  recorrente   Boolean  @default(false)
  diaPagamento Int      @default(5)
  ativa        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries ChartOfAccountEntry[]

  @@index([tenantId])
  @@map("chart_of_accounts")
}

model ChartOfAccountEntry {
  id               String   @id @default(cuid())
  tenantId         String
  chartOfAccountId String
  period           String
  valor            Decimal  @db.Decimal(10, 2)
  status           String   @default("PENDING")
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount @relation(fields: [chartOfAccountId], references: [id], onDelete: Cascade)
  expense        Expense?

  @@unique([chartOfAccountId, period])
  @@index([tenantId, period])
  @@map("chart_of_account_entries")
}

model Expense {
  id                   String   @id @default(cuid())
  tenantId             String
  descricao            String
  valor                Decimal  @db.Decimal(10, 2)
  data                 DateTime
  chartOfAccountEntryId String? @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chartOfAccountEntry ChartOfAccountEntry? @relation(fields: [chartOfAccountEntryId], references: [id])

  @@index([tenantId, data])
  @@map("expenses")
}
